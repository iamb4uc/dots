#!/usr/bin/env bash
set -u

if [ -n "${KITTY_WINDOW_ID-}" ] && command -v kitten >/dev/null 2>&1; then
    kitten icat --clear --stdin=no >/dev/tty 2>/dev/null || true
fi

if [ -n "${LF_UEBERZUG_FIFO-}" ] && [ -p "${LF_UEBERZUG_FIFO}" ] && command -v jq >/dev/null 2>&1; then
    jq -cn --arg identifier "lf-preview" '{action:"remove",identifier:$identifier}' \
        >"$LF_UEBERZUG_FIFO" 2>/dev/null || true
fi

exit 0
